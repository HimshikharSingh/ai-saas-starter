# ==========================================
# AI SaaS Starter Kit - Environment Variables
# ==========================================

# 1. Database (PostgreSQL)
# If using the provided docker-compose:
DATABASE_URL="postgres://postgres:postgres@localhost:5432/saas_db"

# 2. Authentication (JWT)
JWT_SECRET="supersecret_jwt_key_change_in_production"

# 3. AI Service (OpenAI)
OPENAI_API_KEY="sk-proj-YOUR_OPENAI_API_KEY"

# 4. Billing (Stripe)
STRIPE_SECRET_KEY="sk_test_YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_STRIPE_WEBHOOK_SECRET"

# 5. Frontend / Dashboard URL
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
